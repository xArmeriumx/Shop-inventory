flowchart TD
    subgraph SOURCES["Movement Sources"]
        SRC_SALE["SALE<br>Triggered by: createSale<br>Direction: Decrease<br>quantity: -N"]
        SRC_PURCHASE["PURCHASE<br>Triggered by: createPurchase<br>Direction: Increase<br>quantity: +N"]
        SRC_RETURN["RETURN<br>Triggered by: createReturn<br>Direction: Increase<br>quantity: +N"]
        SRC_ADJUST["ADJUSTMENT<br>Triggered by: adjustStock<br>Direction: Increase or Decrease<br>quantity: +/-N"]
        SRC_SALE_CANCEL["SALE_CANCEL<br>Triggered by: cancelSale<br>Direction: Increase<br>quantity: +N (restore)"]
        SRC_PUR_CANCEL["PURCHASE_CANCEL<br>Triggered by: cancelPurchase<br>Direction: Decrease<br>quantity: -N (reverse)"]
    end

    subgraph SERVICE["StockService.recordMovement()"]
        SV1["Receive: productId, shopId,<br>userId, type, quantity, note"]
        SV2["Determine operation:<br>positive qty = increment<br>negative qty = decrement"]
        SV3["Atomic product.update<br>stock: increment or decrement<br>by absolute quantity value"]
        SV4["Read updated product<br>get new stock balance"]
        SV5["Create StockLog record:<br>productId, type, quantity,<br>balanceAfter = new stock,<br>note, saleId / purchaseId / returnId"]
        SV6["Calculate isLowStock:<br>newStock <= product.minStock"]
        SV7{"isLowStock changed?"}
        SV8["Update Product.isLowStock<br>cached boolean flag"]
        SV9{"Newly became low stock?<br>(was false, now true)"}
        SV10["Create Notification:<br>type: LOW_STOCK<br>severity: WARNING<br>title: product name<br>link: /products/productId"]
        SV11["Return: updated product<br>and created StockLog"]

        SV1 --> SV2 --> SV3 --> SV4 --> SV5 --> SV6 --> SV7
        SV7 -->|Yes| SV8 --> SV9
        SV7 -->|No change| SV11
        SV9 -->|Yes| SV10 --> SV11
        SV9 -->|No| SV11
    end

    subgraph RESULT["Resulting State"]
        RES_PRODUCT["Product Record<br>stock: updated balance<br>isLowStock: cached flag<br>version: unchanged"]
        RES_LOG["StockLog Record<br>Complete audit entry with:<br>- movement type<br>- quantity changed<br>- balance after movement<br>- reference to source<br>- timestamp<br>- who performed it"]
        RES_NOTIF["Notification Record<br>Only created when stock<br>drops below minStock threshold<br>for the first time"]
    end

    SRC_SALE --> SV1
    SRC_PURCHASE --> SV1
    SRC_RETURN --> SV1
    SRC_ADJUST --> SV1
    SRC_SALE_CANCEL --> SV1
    SRC_PUR_CANCEL --> SV1

    SV11 --> RES_PRODUCT
    SV11 --> RES_LOG
    SV10 --> RES_NOTIF

    style SOURCES fill:#1a1a2e,color:#e0e0e0
    style SERVICE fill:#16213e,color:#e0e0e0
    style RESULT fill:#0f3460,color:#e0e0e0
