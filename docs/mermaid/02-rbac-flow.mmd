flowchart TD
    subgraph AUTH["Authentication Layer"]
        A1["User submits credentials<br>email + password"] --> A2["NextAuth.js validates<br>against Supabase"]
        A2 --> A3{"Valid?"}
        A3 -->|No| A4["Return 401<br>Unauthorized"]
        A3 -->|Yes| A5["Create JWT Session<br>with userId"]
    end

    subgraph SESSION["Session Context Resolution"]
        A5 --> B1["getSessionContext()"]
        B1 --> B2["Lookup ShopMember<br>WHERE userId = session.userId"]
        B2 --> B3{"Is Shop Owner?"}
        B3 -->|Yes| B4["Return SessionContext<br>role: OWNER<br>permissions: ALL"]
        B3 -->|No| B5["Load Role from ShopMember<br>include permissions array"]
        B5 --> B6["Return SessionContext<br>role: member role name<br>permissions: role.permissions"]
    end

    subgraph GUARD["Permission Guard"]
        B4 --> C1["requirePermission(action)"]
        B6 --> C1
        C1 --> C2{"role === OWNER?"}
        C2 -->|Yes| C3["BYPASS: Allow all actions"]
        C2 -->|No| C4{"permissions.includes(action)?"}
        C4 -->|Yes| C5["ALLOW: Proceed with action"]
        C4 -->|No| C6["DENY: Throw 403 Forbidden<br>Insufficient permissions"]
    end

    subgraph ISOLATION["Multi-Tenant Data Isolation"]
        C3 --> D1["Inject shopId into query<br>WHERE shopId = ctx.shopId"]
        C5 --> D1
        D1 --> D2["Execute Prisma query<br>with tenant filter"]
        D2 --> D3["Return isolated data<br>only from user's shop"]
    end

    style AUTH fill:#1a1a2e,color:#e0e0e0
    style SESSION fill:#16213e,color:#e0e0e0
    style GUARD fill:#0f3460,color:#e0e0e0
    style ISOLATION fill:#1b2d4e,color:#e0e0e0
