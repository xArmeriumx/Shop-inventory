generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "../prisma/dbml"
  projectName = "Shop Inventory ERP"
  projectDatabaseType = "PostgreSQL"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  password         String?
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastActiveAt     DateTime          @default(now())
  sessionVersion   Int               @default(1)
  bankAccounts     BankAccount[]
  customers        Customer[]
  deliveryOrders   DeliveryOrder[]   @relation("UserToDeliveryOrders")
  expenses         Expense[]
  incomes          Income[]
  lookupValues     LookupValue[]
  products         Product[]
  purchases        Purchase[]
  purchaseReturns  PurchaseReturn[]
  returns          Return[]
  sales            Sale[]
  shipments        Shipment[]
  shop             Shop?
  memberships      ShopMember[]
  stockLogs        StockLog[]
  suppliers        Supplier[]
  purchaseReceipts PurchaseReceipt[]
}

model LookupType {
  id          String         @id @default(cuid())
  code        LookupTypeCode @unique
  name        String
  description String?
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  values      LookupValue[]
}

model LookupValue {
  id           String     @id @default(cuid())
  lookupTypeId String
  userId       String?
  code         String
  name         String
  color        String?
  icon         String?
  order        Int        @default(0)
  isActive     Boolean    @default(true)
  isDefault    Boolean    @default(false)
  isSystem     Boolean    @default(false)
  metadata     Json?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  shopId       String?
  expenses     Expense[]
  incomes      Income[]
  lookupType   LookupType @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)
  shop         Shop?      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([lookupTypeId, shopId, code])
  @@index([lookupTypeId, userId, isActive])
  @@index([lookupTypeId, shopId, isActive])
  @@index([userId, deletedAt])
  @@index([shopId, deletedAt])
}

model Shop {
  id                    String                @id @default(cuid())
  name                  String
  address               String?
  phone                 String?
  logo                  String?
  taxId                 String?
  userId                String                @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  invoicePrefix         String?               @default("INV")
  promptPayId           String?
  latitude              Float?
  longitude             Float?
  defaultCurrency       String                @default("THB")
  fiscalYearStart       Int                   @default(1)
  genesisStep           Int                   @default(1)
  industryType          String?
  legalEntityName       String?
  onboardingCompletedAt DateTime?
  onboardingMode        String?
  setupCompletedAt      DateTime?
  signatoryName         String?
  signatoryTitle        String?
  accounts              Account[]
  accountingPeriods     AccountingPeriod[]
  approvalInstances     ApprovalInstance[]
  shippingConfig        Json?
  salesFlowMode         SalesFlowMode         @default(RETAIL)
  inventoryMode         InventoryMode         @default(SIMPLE)
  bankAccounts          BankAccount[]
  bankLines             BankLine[]
  bankStatements        BankStatement[]
  companyTaxProfile     CompanyTaxProfile?
  customers             Customer[]
  deliveryOrders        DeliveryOrder[]
  expenses              Expense[]
  incomes               Income[]
  invoices              Invoice[]
  journalEntries        JournalEntry[]
  lookupValues          LookupValue[]
  notifications         Notification[]
  onboardingProgress    OnboardingProgress?
  orderRequests         OrderRequest[]
  partnerAddresses      PartnerAddress[]
  partnerContacts       PartnerContact[]
  partnerTaxProfiles    PartnerTaxProfile[]
  payments              Payment[]
  paymentAllocations    PaymentAllocation[]
  products              Product[]
  productTaxProfiles    ProductTaxProfile[]
  purchases             Purchase[]
  purchaseReturns       PurchaseReturn[]
  purchaseTaxDocuments  PurchaseTaxDocument[]
  purchaseTaxEntries    PurchaseTaxEntry[]
  quotations            Quotation[]
  returns               Return[]
  roles                 Role[]
  sales                 Sale[]
  salesTaxEntries       SalesTaxEntry[]
  shipments             Shipment[]
  user                  User                  @relation(fields: [userId], references: [id])
  members               ShopMember[]
  stockLogs             StockLog[]
  stockTakeSessions     StockTakeSession[]
  stockTransfers        StockTransfer[]
  suppliers             Supplier[]
  taxCodes              TaxCode[]
  warehouses            Warehouse[]
  warehouseStocks       WarehouseStock[]
  whtCertificates       WhtCertificate[]
  whtCodes              WhtCode[]
  whtEntries            WhtEntry[]
  purchaseReceipts      PurchaseReceipt[]
  purchaseReceiptLines  PurchaseReceiptLine[]
}

model OnboardingProgress {
  id                  String    @id @default(cuid())
  shopId              String    @unique
  wizardDraft         Json?
  wizardVersion       Int       @default(1)
  tutorialTrack       Int       @default(0)
  tutorialStep        Int       @default(0)
  tutorialDismissed   Boolean   @default(false)
  dismissedSetupItems String[]
  lastSetupViewedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean      @default(false)
  isSystem    Boolean      @default(false)
  shopId      String
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  members     ShopMember[]

  @@unique([shopId, name])
  @@index([shopId])
}

model ShopMember {
  id                     String                @id @default(cuid())
  userId                 String
  shopId                 String
  roleId                 String
  isOwner                Boolean               @default(false)
  joinedAt               DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  permissionVersion      Int                   @default(1)
  departmentCode         String?
  regionIds              String[]
  closedPeriods          AccountingPeriod[]    @relation("ClosedByMember")
  reopenedPeriods        AccountingPeriod[]    @relation("ReopenedByMember")
  bankLines              BankLine[]
  bankStatements         BankStatement[]
  createdDOs             DeliveryOrder[]       @relation("DOToMember")
  createdExpenses        Expense[]             @relation("ExpenseToMember")
  createdIncomes         Income[]              @relation("IncomeToMember")
  createdInvoices        Invoice[]             @relation("InvoiceToMember")
  journalEntries         JournalEntry[]
  createdOrderRequests   OrderRequest[]        @relation("OrderRequestToMember")
  orderRequests          OrderRequest[]
  payments               Payment[]
  createdProducts        Product[]             @relation("ProductToMember")
  createdPurchases       Purchase[]            @relation("PurchaseToMember")
  createdPurchaseReturns PurchaseReturn[]      @relation("PurchaseReturnToMember")
  purchaseTaxDocsCreated PurchaseTaxDocument[] @relation("PurchTaxCreator")
  purchaseTaxDocsPosted  PurchaseTaxDocument[] @relation("PurchTaxPoster")
  purchaseTaxDocsVoided  PurchaseTaxDocument[] @relation("PurchTaxVoider")
  createdQuotations      Quotation[]           @relation("QuotationToMember")
  quotations             Quotation[]
  createdReturns         Return[]              @relation("ReturnToMember")
  createdSales           Sale[]                @relation("SaleToMember")
  createdShipments       Shipment[]            @relation("ShipmentToMember")
  role                   Role                  @relation(fields: [roleId], references: [id])
  shop                   Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdStockLogs       StockLog[]            @relation("StockLogToMember")
  cancelledStockTakes    StockTakeSession[]    @relation("StockTakeCanceller")
  completedStockTakes    StockTakeSession[]    @relation("StockTakeCompleter")
  createdStockTakes      StockTakeSession[]    @relation("StockTakeCreator")
  submittedStockTakes    StockTakeSession[]    @relation("StockTakeSubmitter")
  stockTransfers         StockTransfer[]
  whtEntries             WhtEntry[]
  customers              Customer[]            @relation("CustomerToShopMember")
  purchaseReceipts       PurchaseReceipt[]

  @@unique([userId, shopId])
  @@index([userId, permissionVersion])
  @@index([userId])
}

model Product {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  sku                  String?
  category             String
  costPrice            Decimal               @db.Decimal(10, 2)
  salePrice            Decimal               @db.Decimal(10, 2)
  stock                Int                   @default(0)
  minStock             Int                   @default(5)
  images               String[]
  isActive             Boolean               @default(true)
  userId               String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  categoryId           String?
  shopId               String
  isLowStock           Boolean               @default(false)
  supplierId           String?
  version              Int                   @default(1)
  avgLeadTime          Int?
  isSaleable           Boolean               @default(true)
  metadata             Json?
  moq                  Int?
  reservedStock        Int                   @default(0)
  packagingQty         Int                   @default(1)
  memberId             String?
  deliveryOrderLines   DeliveryOrderLine[]
  invoiceLines         InvoiceLine[]
  orderRequestLines    OrderRequestLine[]
  categoryRef          LookupValue?          @relation(fields: [categoryId], references: [id])
  member               ShopMember?           @relation("ProductToMember", fields: [memberId], references: [id])
  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseItems        PurchaseItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  purchaseReceiptLines PurchaseReceiptLine[]
  quotationLines       QuotationLine[]
  returnItems          ReturnItem[]
  saleItems            SaleItem[]
  stockLogs            StockLog[]
  stockTakeItems       StockTakeItem[]
  transferLines        StockTransferLine[]
  supplierProducts     SupplierProduct[]
  warehouseStocks      WarehouseStock[]

  @@unique([shopId, sku])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])
  @@index([shopId, isLowStock])
  @@index([category])
  @@index([categoryId])
  @@index([name])
  @@index([shopId, deletedAt, isActive])
  @@index([shopId, deletedAt])
  @@index([shopId, isActive, stock])
}

model Warehouse {
  id                   String                @id @default(cuid())
  name                 String
  code                 String
  address              String?
  isDefault            Boolean               @default(false)
  isActive             Boolean               @default(true)
  shopId               String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  outgoingTransfers    StockTransfer[]       @relation("FromWarehouse")
  incomingTransfers    StockTransfer[]       @relation("ToWarehouse")
  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  stocks               WarehouseStock[]
  purchaseReceiptLines PurchaseReceiptLine[]
  stockLogs            StockLog[]
  saleItems            SaleItem[]
  returnItems          ReturnItem[]

  @@unique([shopId, code])
  @@index([shopId])
}

enum InventoryMode {
  SIMPLE
  SINGLE
  MULTI
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  shopId      String
  quantity    Int       @default(0)
  reservedStock Int     @default(0)
  minStock    Int?
  binLocation String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
  @@index([shopId])
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNo      String
  status          TransferStatus      @default(DRAFT)
  transferDate    DateTime            @default(now())
  fromWarehouseId String
  toWarehouseId   String
  notes           String?
  shopId          String
  memberId        String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fromWarehouse   Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  member          ShopMember          @relation(fields: [memberId], references: [id])
  shop            Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  lines           StockTransferLine[]

  @@unique([shopId, transferNo])
  @@index([shopId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferLine {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
}

model Supplier {
  id                   String                @id @default(cuid())
  name                 String                @db.VarChar(200)
  phone                String?               @db.VarChar(20)
  address              String?
  notes                String?
  userId               String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  shopId               String
  code                 String?               @db.VarChar(50)
  contactName          String?               @db.VarChar(100)
  email                String?               @db.VarChar(100)
  taxId                String?               @db.VarChar(20)
  groupCode            String?               @db.VarChar(50)
  moq                  Decimal?              @db.Decimal(10, 2)
  purchaseNote         String?
  latitude             Float?
  longitude            Float?
  creditLimit          Decimal?              @db.Decimal(10, 2)
  creditTerm           Int?
  paymentTerms         String?
  partnerAddresses     PartnerAddress[]
  products             Product[]
  purchases            Purchase[]
  purchaseTaxDocuments PurchaseTaxDocument[]
  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplierProducts     SupplierProduct[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])
  @@index([name])
}

model Customer {
  id               String           @id @default(cuid())
  name             String
  phone            String?
  address          String?
  notes            String?
  userId           String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  taxId            String?
  shopId           String
  email            String?
  creditLimit      Decimal?         @db.Decimal(10, 2)
  creditTerm       Int?
  groupCode        String?
  region           String?
  latitude         Float?
  longitude        Float?
  billingAddress   String?
  shippingAddress  String?
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  partnerAddresses PartnerAddress[]
  quotations       Quotation[]
  sales            Sale[]
  salesPersons     ShopMember[]     @relation("CustomerToShopMember")

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])
  @@index([name])
}

model Purchase {
  id               String                    @id @default(cuid())
  date             DateTime                  @default(now())
  supplierId       String?
  totalCost        Decimal                   @db.Decimal(10, 2)
  receiptUrl       String?
  notes            String?
  userId           String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  supplierName     String?
  cancelReason     String?
  cancelledAt      DateTime?
  cancelledBy      String?
  status           String                    @default("ACTIVE")
  shopId           String
  purchaseNumber   String?
  paymentMethod    String                    @default("CASH")
  docType          String                    @default("ORDER")
  linkedPRId       String?
  purchaseType     String                    @default("LOCAL")
  requestNumber    String?
  receivedAt       DateTime?
  receivedBy       String?
  memberId         String?
  paidAmount       Decimal                   @default(0) @db.Decimal(20, 4)
  paymentStatus    String                    @default("UNPAID")
  residualAmount   Decimal                   @default(0) @db.Decimal(20, 4)
  approvals        ApprovalInstance[]
  payments         Payment[]
  allocations      PaymentAllocation[]
  member           ShopMember?               @relation("PurchaseToMember", fields: [memberId], references: [id])
  shop             Shop                      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier         Supplier?                 @relation(fields: [supplierId], references: [id])
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            PurchaseItem[]
  purchaseReturns  PurchaseReturn[]
  purchaseTaxLinks PurchaseTaxDocumentLink[]
  stockLogs        StockLog[]
  whtEntries       WhtEntry[]
  purchaseReceipts PurchaseReceipt[]

  @@unique([shopId, purchaseNumber])
  @@index([userId])
  @@index([userId, date])
  @@index([userId, status])
  @@index([shopId])
  @@index([date])
  @@index([supplierId])
  @@index([shopId, date, status])
  @@index([shopId, status])
}

model PurchaseItem {
  id                  String                @id @default(cuid())
  purchaseId          String
  productId           String
  quantity            Int
  receivedQuantity    Int                   @default(0)
  costPrice           Decimal               @db.Decimal(10, 2)
  subtotal            Decimal               @db.Decimal(10, 2)
  packagingQty        Int                   @default(1)
  product             Product               @relation(fields: [productId], references: [id])
  purchase            Purchase              @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseReturnItems PurchaseReturnItem[]
  receiptLines        PurchaseReceiptLine[]

  @@index([purchaseId])
  @@index([productId])
}

model Sale {
  id                String    @id @default(cuid())
  invoiceNumber     String
  date              DateTime  @default(now())
  customerId        String?
  customerName      String?
  customerAddress   String?
  customerPhone     String?
  totalAmount       Decimal   @db.Decimal(10, 2)
  totalCost         Decimal   @db.Decimal(10, 2)
  profit            Decimal   @db.Decimal(10, 2)
  paymentMethod     String
  notes             String?
  userId            String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  receiptUrl        String?
  cancelReason      String?
  cancelledAt       DateTime?
  cancelledBy       String?
  status            String    @default("ACTIVE")
  shopId            String
  discountAmount    Decimal   @default(0) @db.Decimal(10, 2)
  discountType      String?
  discountValue     Decimal?  @db.Decimal(10, 2)
  netAmount         Decimal   @default(0) @db.Decimal(10, 2)
  paymentNote       String?
  paymentProof      String?
  paymentVerifiedAt DateTime?
  paymentVerifiedBy String?
  channel           String    @default("WALK_IN")

  // Tax Snapshot (G10 Standard)
  taxMode       String  @default("INCLUSIVE")
  taxRate       Decimal @default(7) @db.Decimal(5, 2)
  taxAmount     Decimal @default(0) @db.Decimal(14, 2)
  taxableAmount Decimal @default(0) @db.Decimal(14, 2)

  billingStatus      String             @default("UNBILLED")
  bookingStatus      String             @default("NONE")
  deliveryStatus     String             @default("PENDING")
  departmentCode     String?
  isLocked           Boolean            @default(false)
  memberId           String?
  paidAmount         Decimal            @default(0) @db.Decimal(10, 2)
  paymentStatusProof String             @default("VERIFIED")
  residualAmount     Decimal            @default(0) @db.Decimal(10, 2)
  paymentStatus      DocPaymentStatus   @default(UNPAID)
  editLockStatus     String             @default("NONE")
  lockReason         String?
  orderRequestId     String?
  quotationId        String?
  approvals          ApprovalInstance[]
  deliveryOrders     DeliveryOrder[]
  invoices           Invoice?
  payments           Payment[]
  returns            Return[]
  customer           Customer?          @relation(fields: [customerId], references: [id])
  member             ShopMember?        @relation("SaleToMember", fields: [memberId], references: [id])
  orderRequest       OrderRequest?      @relation(fields: [orderRequestId], references: [id])
  quotation          Quotation?         @relation("QuotationToSale", fields: [quotationId], references: [id])
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              SaleItem[]
  shipments          Shipment[]
  stockLogs          StockLog[]

  // ── Child Tables (1-to-1 Normalization) ──
  statusDetail       SaleStatus?
  taxSummary         SaleTaxSummary?
  paymentDetail      SalePaymentDetail?

  @@unique([shopId, invoiceNumber])
  @@index([userId])
  @@index([userId, date])
  @@index([userId, status])
  @@index([shopId])
  @@index([date])
  @@index([customerId])
  @@index([shopId, date, status])
  @@index([shopId, status])
  @@index([shopId, paymentStatus])
  @@index([shopId, channel])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sale Child Tables (1-to-1 Normalization)
// เหตุผล: แยก Sale God Object (45 fields) เพื่อลด Row Size และ Lock Contention
// ─────────────────────────────────────────────────────────────────────────────

/// สถานะเอกสารทั้งหมดของบิลขาย
/// รวม isLocked + editLockStatus เป็น editLockStatus เดียว (Impossible State Fix)
model SaleStatus {
  id             String           @id @default(cuid())
  saleId         String           @unique
  sale           Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)

  // Document Lifecycle Status
  status         String           @default("ACTIVE")    // DRAFT, CONFIRMED, COMPLETED, CANCELLED, INVOICED
  paymentStatus  DocPaymentStatus @default(UNPAID)       // UNPAID, PARTIAL, PAID, VOIDED
  billingStatus  String           @default("UNBILLED")   // UNBILLED, BILLED
  deliveryStatus String           @default("PENDING")    // PENDING, SHIPPED, DELIVERED
  bookingStatus  String           @default("NONE")       // NONE, RESERVED, DEDUCTED

  // Lock System — ยุบ isLocked (Boolean) + editLockStatus (String) รวมเป็น 1 ฟิลด์
  editLockStatus String           @default("NONE")       // NONE, LOCKED, CLOSED_PERIOD
  lockReason     String?

  // Cancellation Tracking
  cancelReason   String?
  cancelledAt    DateTime?
  cancelledBy    String?

  shopId    String
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([shopId, status])
  @@index([shopId, paymentStatus])
  @@index([shopId, deliveryStatus])
}

/// ข้อมูลภาษีของบิลขาย (อ่านเฉพาะตอนออกใบกำกับภาษีและรายงาน)
model SaleTaxSummary {
  id            String   @id @default(cuid())
  saleId        String   @unique
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  taxMode       String   @default("INCLUSIVE")  // INCLUSIVE, EXCLUSIVE, NO_VAT
  taxRate       Decimal  @default(7)  @db.Decimal(5, 2)
  taxAmount     Decimal  @default(0)  @db.Decimal(14, 2)
  taxableAmount Decimal  @default(0)  @db.Decimal(14, 2)

  shopId    String
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([shopId])
}

/// รายละเอียดการรับชำระและหลักฐานสลิป (Row ใหญ่ แยกออกเพื่อลด Payload หน้า List)
model SalePaymentDetail {
  id                 String    @id @default(cuid())
  saleId             String    @unique
  sale               Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  paymentMethod      String    @default("CASH")
  paymentProof       String?   // URL ไฟล์สลิป
  paymentNote        String?
  paymentVerifiedAt  DateTime?
  paymentVerifiedBy  String?
  paymentStatusProof String    @default("VERIFIED")  // PENDING, VERIFIED, REJECTED

  paidAmount     Decimal @default(0) @db.Decimal(10, 2)
  residualAmount Decimal @default(0) @db.Decimal(10, 2)

  shopId    String
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([shopId])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  productId      String
  quantity       Int
  salePrice      Decimal @db.Decimal(10, 2)
  costPrice      Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  profit         Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  // Tax Snapshot (G10 Standard)
  taxAmount     Decimal @default(0) @db.Decimal(14, 2)
  taxableAmount Decimal @default(0) @db.Decimal(14, 2)

  packagingQty Int          @default(1)
  warehouseId  String?
