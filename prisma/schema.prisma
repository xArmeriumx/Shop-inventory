generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  shop          Shop?
  memberships   ShopMember[]  // RBAC: User can be member of multiple shops
  products      Product[]
  purchases     Purchase[]
  sales         Sale[]
  expenses      Expense[]
  suppliers     Supplier[]
  customers     Customer[]
  lookupValues  LookupValue[]
  stockLogs     StockLog[]
}

// ==================== Lookup System (Custom Dropdowns) ====================

enum LookupTypeCode {
  PRODUCT_CATEGORY
  EXPENSE_CATEGORY
  PAYMENT_METHOD
  UNIT
}

model LookupType {
  id          String         @id @default(cuid())
  code        LookupTypeCode @unique
  name        String
  description String?
  isSystem    Boolean        @default(false)
  
  values      LookupValue[]
  
  createdAt   DateTime       @default(now())
}

model LookupValue {
  id           String         @id @default(cuid())
  lookupTypeId String
  userId       String?
  shopId       String?  // RBAC: Data visibility scope
  
  code         String
  name         String
  color        String?
  icon         String?
  order        Int            @default(0)
  isActive     Boolean        @default(true)
  isDefault    Boolean        @default(false)
  isSystem     Boolean        @default(false)
  metadata     Json?
  
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lookupType   LookupType     @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop         Shop?          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  // Reverse relations
  products     Product[]
  expenses     Expense[]

  // Allow unique codes per shop, or per user (legacy), or system (nulls)
  // Note: Validation should handle enforcement preference
  @@unique([lookupTypeId, shopId, code]) 
  // We keep the old unique constraint? No, migration might fail if duplicates exist when shopId is null for many?
  // Postgres treats NULLs as distinct for unique, so unique([type, null, code]) and unique([type, null, code]) are allowed duplicates?
  // Actually no, standard SQL unique allows multiple nulls.
  // But we want to enforce uniqueness per shop. 
  // Let's add the index and handle logic in app or refine constraint later.
  // For now, index is important.
  
  @@index([lookupTypeId, userId, isActive])
  @@index([lookupTypeId, shopId, isActive])
  @@index([userId, deletedAt])
  @@index([shopId, deletedAt])
}


// ==================== Shop (Multi-tenancy) ====================

model Shop {
  id          String   @id @default(cuid())
  name        String   // ชื่อร้าน
  address     String?  // ที่อยู่ (สำหรับใบเสร็จ)
  phone       String?  // เบอร์ติดต่อ
  logo        String?  // URL โลโก้
  taxId       String?  // เลขประจำตัวผู้เสียภาษี

  // Original owner (for billing, cannot be removed)
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // RBAC Relations
  members     ShopMember[]
  roles       Role[]

  // Data ownership relations
  products    Product[]
  suppliers   Supplier[]
  customers   Customer[]
  purchases   Purchase[]
  sales       Sale[]
  expenses    Expense[]
  stockLogs   StockLog[]
  lookupValues LookupValue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== RBAC (Role-Based Access Control) ====================

enum Permission {
  // Product
  PRODUCT_VIEW
  PRODUCT_CREATE
  PRODUCT_EDIT
  PRODUCT_DELETE
  PRODUCT_VIEW_COST       // Sensitive: ดูต้นทุน

  // Stock
  STOCK_VIEW_HISTORY
  STOCK_ADJUST

  // Sales
  SALE_VIEW
  SALE_CREATE
  SALE_VIEW_PROFIT        // Sensitive: ดูกำไร
  SALE_CANCEL

  // Purchases
  PURCHASE_VIEW
  PURCHASE_CREATE
  PURCHASE_CANCEL

  // Customers
  CUSTOMER_VIEW
  CUSTOMER_CREATE
  CUSTOMER_EDIT
  CUSTOMER_DELETE

  // Expenses
  EXPENSE_VIEW
  EXPENSE_CREATE
  EXPENSE_EDIT
  EXPENSE_DELETE

  // Reports
  REPORT_VIEW_SALES
  REPORT_VIEW_PROFIT      // Sensitive: ดูกำไรในรายงาน
  REPORT_EXPORT

  // Settings
  SETTINGS_SHOP
  SETTINGS_LOOKUPS

  // Team
  TEAM_VIEW
  TEAM_INVITE
  TEAM_EDIT
  TEAM_REMOVE

  // POS
  POS_ACCESS
}

model Role {
  id          String       @id @default(cuid())
  name        String       // e.g., "พนักงานขาย", "ผู้จัดการ"
  description String?
  isDefault   Boolean      @default(false)  // Default role for new invites
  isSystem    Boolean      @default(false)  // OWNER role, undeletable

  shopId      String
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  permissions Permission[]

  members     ShopMember[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([shopId, name])
  @@index([shopId])
}

model ShopMember {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  isOwner   Boolean  @default(false)  // Shortcut flag for Owner
  
  // Permission version counter - increments when role changes
  // Used for smart client-side polling (only fetch full data when version changes)
  permissionVersion Int @default(0)

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, shopId])  // A user can only be in a shop once
  @@index([shopId])
  @@index([userId])
}

// ==================== Core Models ====================

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  // Compound unique below
  category    String   // Legacy field for backward compatibility
  categoryId  String?  // FK to LookupValue

  costPrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)

  images      String[]
  isActive    Boolean  @default(true)

  // Ownership (keeping userId for audit, adding shopId for RBAC)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String?  // RBAC: Nullable during transition
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  stockLogs     StockLog[]

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, sku])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([category])
  @@index([categoryId])
  @@index([name])
  @@index([isActive])
}


model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  notes     String?

  // Ownership
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId    String?  // RBAC: Nullable during transition
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  purchases Purchase[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  taxId     String?
  notes     String?

  // Ownership
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId    String?  // RBAC: Nullable during transition
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sales     Sale[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([name])
}

// ==================== Transactions ====================

model Purchase {
  id          String   @id @default(cuid())
  date        DateTime @default(now())

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  supplierName String? // Manual supplier name (when not using Supplier)

  totalCost   Decimal  @db.Decimal(10, 2)
  receiptUrl  String?
  notes       String?

  // Ownership
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String?  // RBAC: Nullable during transition
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items       PurchaseItem[]

  // Cancel/Void (Audit-Ready)
  status        String    @default("ACTIVE")  // ACTIVE | CANCELLED
  cancelledAt   DateTime?
  cancelledBy   String?   // User name who cancelled
  cancelReason  String?   // Reason for cancellation

  // Soft Delete (legacy, use status instead)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([userId, status])  // For filtering active/cancelled
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([supplierId])
}

model PurchaseItem {
  id          String   @id @default(cuid())

  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
  @@index([productId])
}

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   // Compound unique below
  date          DateTime @default(now())

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String?

  totalAmount   Decimal  @db.Decimal(10, 2)
  totalCost     Decimal  @db.Decimal(10, 2)
  profit        Decimal  @db.Decimal(10, 2)

  paymentMethod String
  notes         String?
  receiptUrl    String?

  // Ownership
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId        String?  // RBAC: Nullable during transition
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items         SaleItem[]

  // Cancel/Void (Audit-Ready)
  status        String    @default("ACTIVE")  // ACTIVE | CANCELLED
  cancelledAt   DateTime?
  cancelledBy   String?   // User name who cancelled
  cancelReason  String?   // Reason for cancellation

  // Soft Delete (legacy, use status instead)
  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([userId, status])  // For filtering active/cancelled
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([customerId])
}

model SaleItem {
  id          String   @id @default(cuid())

  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  salePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  profit      Decimal  @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // Legacy field for backward compatibility
  categoryId  String?  // FK to LookupValue
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  date        DateTime @default(now())
  receiptUrl  String?

  // Ownership
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String?  // RBAC: Nullable during transition
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([category])
  @@index([categoryId])
}


// ==================== Stock Management ====================

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  WASTE
  CANCEL
  SALE_CANCEL
  PURCHASE_CANCEL
}

model StockLog {
  id            String            @id @default(cuid())
  type          StockMovementType
  
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  
  quantity      Int
  balance       Int              // Balance snapshot after movement
  
  referenceId   String?           // Sale ID, Purchase ID, etc
  referenceType String?           // "SALE", "PURCHASE"
  note          String?
  
  date          DateTime          @default(now())
  
  // Ownership
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId        String?           // RBAC: Nullable during transition
  shop          Shop?             @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt     DateTime          @default(now())

  @@index([productId, date])
  @@index([userId, date])
  @@index([shopId])  // RBAC index
  @@index([referenceId])
}
