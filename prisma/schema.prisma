generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  shop          Shop?
  products      Product[]
  purchases     Purchase[]
  sales         Sale[]
  expenses      Expense[]
  suppliers     Supplier[]
  customers     Customer[]
  lookupValues  LookupValue[]
}

// ==================== Lookup System (Custom Dropdowns) ====================

enum LookupTypeCode {
  PRODUCT_CATEGORY
  EXPENSE_CATEGORY
  PAYMENT_METHOD
  UNIT
}

model LookupType {
  id          String         @id @default(cuid())
  code        LookupTypeCode @unique
  name        String
  description String?
  isSystem    Boolean        @default(false)
  
  values      LookupValue[]
  
  createdAt   DateTime       @default(now())
}

model LookupValue {
  id           String         @id @default(cuid())
  lookupTypeId String
  userId       String?
  
  code         String
  name         String
  color        String?
  icon         String?
  order        Int            @default(0)
  isActive     Boolean        @default(true)
  isDefault    Boolean        @default(false)
  isSystem     Boolean        @default(false)
  metadata     Json?
  
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lookupType   LookupType     @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Reverse relations
  products     Product[]
  expenses     Expense[]

  @@unique([lookupTypeId, userId, code])
  @@index([lookupTypeId, userId, isActive])
  @@index([userId, deletedAt])
}


// ==================== Shop (Multi-tenancy) ====================

model Shop {
  id          String   @id @default(cuid())
  name        String   // ชื่อร้าน
  address     String?  // ที่อยู่ (สำหรับใบเสร็จ)
  phone       String?  // เบอร์ติดต่อ
  logo        String?  // URL โลโก้
  taxId       String?  // เลขประจำตัวผู้เสียภาษี

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Core Models ====================

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  // Compound unique below
  category    String   // Legacy field for backward compatibility
  categoryId  String?  // FK to LookupValue

  costPrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)

  images      String[]
  isActive    Boolean  @default(true)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, sku])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([category])
  @@index([categoryId])
  @@index([name])
  @@index([isActive])
}


model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  notes     String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  purchases Purchase[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  taxId     String?
  notes     String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sales     Sale[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([name])
}

// ==================== Transactions ====================

model Purchase {
  id          String   @id @default(cuid())
  date        DateTime @default(now())

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  supplierName String? // Manual supplier name (when not using Supplier)

  totalCost   Decimal  @db.Decimal(10, 2)
  receiptUrl  String?
  notes       String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items       PurchaseItem[]

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([date])
  @@index([supplierId])
}

model PurchaseItem {
  id          String   @id @default(cuid())

  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
  @@index([productId])
}

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   // Compound unique below
  date          DateTime @default(now())

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String?

  totalAmount   Decimal  @db.Decimal(10, 2)
  totalCost     Decimal  @db.Decimal(10, 2)
  profit        Decimal  @db.Decimal(10, 2)

  paymentMethod String
  notes         String?
  receiptUrl    String?

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items         SaleItem[]

  // Soft Delete
  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([date])
  @@index([customerId])
}

model SaleItem {
  id          String   @id @default(cuid())

  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  salePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  profit      Decimal  @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // Legacy field for backward compatibility
  categoryId  String?  // FK to LookupValue
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  date        DateTime @default(now())
  receiptUrl  String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([date])
  @@index([category])
  @@index([categoryId])
}

