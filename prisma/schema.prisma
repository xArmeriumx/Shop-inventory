generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastActiveAt  DateTime  @default(now()) // Track online status

  // Relations
  shop          Shop?
  memberships   ShopMember[]  // RBAC: User can be member of multiple shops
  products      Product[]
  purchases     Purchase[]
  sales         Sale[]
  expenses      Expense[]
  incomes       Income[]
  suppliers     Supplier[]
  customers     Customer[]
  lookupValues  LookupValue[]
  stockLogs     StockLog[]
  shipments     Shipment[]
  returns       Return[]      // G3: Returns
}

// ==================== Lookup System (Custom Dropdowns) ====================

enum LookupTypeCode {
  PRODUCT_CATEGORY
  EXPENSE_CATEGORY
  INCOME_CATEGORY
  PAYMENT_METHOD
  UNIT
}

model LookupType {
  id          String         @id @default(cuid())
  code        LookupTypeCode @unique
  name        String
  description String?
  isSystem    Boolean        @default(false)
  
  values      LookupValue[]
  
  createdAt   DateTime       @default(now())
}

model LookupValue {
  id           String         @id @default(cuid())
  lookupTypeId String
  userId       String?
  shopId       String?  // RBAC: Data visibility scope
  
  code         String
  name         String
  color        String?
  icon         String?
  order        Int            @default(0)
  isActive     Boolean        @default(true)
  isDefault    Boolean        @default(false)
  isSystem     Boolean        @default(false)
  metadata     Json?
  
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lookupType   LookupType     @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop         Shop?          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  // Reverse relations
  products     Product[]
  expenses     Expense[]
  incomes      Income[]

  // Allow unique codes per shop, or per user (legacy), or system (nulls)
  // Note: Validation should handle enforcement preference
  @@unique([lookupTypeId, shopId, code]) 
  // We keep the old unique constraint? No, migration might fail if duplicates exist when shopId is null for many?
  // Postgres treats NULLs as distinct for unique, so unique([type, null, code]) and unique([type, null, code]) are allowed duplicates?
  // Actually no, standard SQL unique allows multiple nulls.
  // But we want to enforce uniqueness per shop. 
  // Let's add the index and handle logic in app or refine constraint later.
  // For now, index is important.
  
  @@index([lookupTypeId, userId, isActive])
  @@index([lookupTypeId, shopId, isActive])
  @@index([userId, deletedAt])
  @@index([shopId, deletedAt])
}


// ==================== Shop (Multi-tenancy) ====================

model Shop {
  id          String   @id @default(cuid())
  name        String   // ชื่อร้าน
  address     String?  // ที่อยู่ (สำหรับใบเสร็จ)
  phone       String?  // เบอร์ติดต่อ
  logo        String?  // URL โลโก้
  taxId       String?  // เลขประจำตัวผู้เสียภาษี
  invoicePrefix String? @default("INV")  // G2: prefix ใบกำกับภาษี

  // Original owner (for billing, cannot be removed)
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  // RBAC Relations
  members     ShopMember[]
  roles       Role[]

  // Data ownership relations
  products    Product[]
  suppliers   Supplier[]
  customers   Customer[]
  purchases   Purchase[]
  sales       Sale[]
  expenses    Expense[]
  incomes     Income[]
  stockLogs   StockLog[]
  lookupValues LookupValue[]
  shipments        Shipment[]
  customerAddresses CustomerAddress[]
  returns          Return[]
  notifications    Notification[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== RBAC (Role-Based Access Control) ====================

enum Permission {
  // Product
  PRODUCT_VIEW
  PRODUCT_CREATE
  PRODUCT_EDIT
  PRODUCT_DELETE
  PRODUCT_VIEW_COST       // Sensitive: ดูต้นทุน

  // Stock
  STOCK_VIEW_HISTORY
  STOCK_ADJUST

  // Sales
  SALE_VIEW
  SALE_CREATE
  SALE_VIEW_PROFIT        // Sensitive: ดูกำไร
  SALE_CANCEL

  // Returns (G3)
  RETURN_VIEW
  RETURN_CREATE

  // Payment Verification (G1)
  PAYMENT_VERIFY

  // Purchases
  PURCHASE_VIEW
  PURCHASE_CREATE
  PURCHASE_CANCEL

  // Customers
  CUSTOMER_VIEW
  CUSTOMER_CREATE
  CUSTOMER_EDIT
  CUSTOMER_DELETE

  // Suppliers
  SUPPLIER_VIEW
  SUPPLIER_CREATE
  SUPPLIER_EDIT
  SUPPLIER_DELETE

  // Expenses
  EXPENSE_VIEW
  EXPENSE_CREATE
  EXPENSE_EDIT
  EXPENSE_DELETE

  // Income (รายรับที่เพิ่มเอง)
  INCOME_VIEW
  INCOME_CREATE
  INCOME_EDIT
  INCOME_DELETE

  // Reports
  REPORT_VIEW_SALES
  REPORT_VIEW_PROFIT      // Sensitive: ดูกำไรในรายงาน
  REPORT_EXPORT

  // Settings
  SETTINGS_SHOP
  SETTINGS_LOOKUPS

  // Team
  TEAM_VIEW
  TEAM_INVITE
  TEAM_EDIT
  TEAM_REMOVE

  // POS
  POS_ACCESS

  // Shipments
  SHIPMENT_VIEW
  SHIPMENT_CREATE
  SHIPMENT_EDIT
  SHIPMENT_CANCEL
}

model Role {
  id          String       @id @default(cuid())
  name        String       // e.g., "พนักงานขาย", "ผู้จัดการ"
  description String?
  isDefault   Boolean      @default(false)  // Default role for new invites
  isSystem    Boolean      @default(false)  // OWNER role, undeletable

  shopId      String
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  permissions Permission[]

  members     ShopMember[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([shopId, name])
  @@index([shopId])
}

model ShopMember {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  isOwner   Boolean  @default(false)  // Shortcut flag for Owner
  
  // Permission version counter - increments when role changes
  // Used for smart client-side polling (only fetch full data when version changes)
  permissionVersion Int @default(0)

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, shopId])  // A user can only be in a shop once
  @@index([shopId])
  @@index([userId])
}

// ==================== Core Models ====================

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  // Compound unique below
  category    String   // @deprecated — use categoryRef (categoryId) instead. Kept for legacy data.
  categoryId  String?  // FK to LookupValue

  costPrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)

  images      String[]
  isActive    Boolean  @default(true)
  isLowStock  Boolean  @default(false)
  version     Int      @default(1)  // Optimistic locking version

  // Ownership (keeping userId for audit, adding shopId for RBAC)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String   // Required for tenant isolation
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Primary Supplier (for re-ordering)
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  stockLogs     StockLog[]
  returnItems   ReturnItem[]  // G3: Returns

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, sku])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([shopId, isLowStock])
  @@index([category])
  @@index([categoryId])
  @@index([name])
  @@index([isActive])
}


model Supplier {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(200)
  code        String?  @db.VarChar(50)  // รหัสผู้จำหน่าย
  
  // Contact Info
  contactName String?  @db.VarChar(100) // ชื่อผู้ติดต่อ
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(100)
  address     String?  @db.Text
  
  // Tax Info
  taxId       String?  @db.VarChar(20)  // เลขผู้เสียภาษี
  
  notes       String?  @db.Text

  // Ownership
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId    String   // Required for tenant isolation
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  purchases Purchase[]
  products  Product[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  taxId     String?
  notes     String?

  // Ownership
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId    String   // Required for tenant isolation
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sales     Sale[]
  addresses CustomerAddress[]

  // Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([shopId])  // RBAC index
  @@index([name])
}

// ==================== Transactions ====================

model Purchase {
  id              String   @id @default(cuid())
  purchaseNumber  String?  // PUR-00001 (auto-gen per shop)
  date            DateTime @default(now())

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  supplierName String? // @deprecated — use supplier (supplierId) instead. Kept for legacy data.

  totalCost   Decimal  @db.Decimal(10, 2)
  paymentMethod String  @default("CASH")  // CASH | TRANSFER | CREDIT
  receiptUrl  String?
  notes       String?

  // Ownership
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String   // Required for tenant isolation
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items       PurchaseItem[]
  stockLogs   StockLog[]

  // Cancel/Void (Audit-Ready)
  status        String    @default("ACTIVE")  // ACTIVE | CANCELLED
  cancelledAt   DateTime?
  cancelledBy   String?   // User name who cancelled
  cancelReason  String?   // Reason for cancellation

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, purchaseNumber])
  @@index([userId])
  @@index([userId, date])
  @@index([userId, status])  // For filtering active/cancelled
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([supplierId])
  
  // ✅ NEW: Compound indexes for optimized queries
  @@index([shopId, date, status])  // Purchases list with date range + status
  @@index([shopId, status])        // Purchases filtered by status
}

model PurchaseItem {
  id          String   @id @default(cuid())

  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
  @@index([productId])
}

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   // Compound unique below
  date          DateTime @default(now())

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String?  // @deprecated — use customer (customerId) instead. Kept for legacy data.

  totalAmount   Decimal  @db.Decimal(10, 2)
  totalCost     Decimal  @db.Decimal(10, 2)
  profit        Decimal  @db.Decimal(10, 2)

  // G4: Discounts
  discountType  String?   // "PERCENT" | "FIXED" | null (ไม่มีส่วนลด)
  discountValue Decimal?  @db.Decimal(10, 2)  // ค่าที่ระบุ (% หรือจำนวนเงิน)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)  // จำนวนเงินที่ลดจริง (คำนวณแล้ว)
  netAmount     Decimal  @default(0) @db.Decimal(10, 2)  // ยอดสุทธิ = totalAmount - discountAmount

  paymentMethod String
  notes         String?
  receiptUrl    String?

  // G1: Payment Verification
  paymentStatus     String    @default("VERIFIED")  // PENDING | VERIFIED | REJECTED
  paymentProof      String?   // Slip image URL
  paymentVerifiedAt DateTime? // When payment was verified
  paymentVerifiedBy String?   // UserId who verified
  paymentNote       String?   // หมายเหตุ (เหตุผล reject, etc.)

  // Sales Channel Tracking
  channel           String    @default("WALK_IN")  // WALK_IN | SHOPEE | LAZADA | LINE | FACEBOOK | OTHER

  // Ownership
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId        String   // Required for tenant isolation
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items         SaleItem[]
  stockLogs     StockLog[]
  shipments     Shipment[]
  returns       Return[]     // G3: Returns

  // Cancel/Void (Audit-Ready)
  status        String    @default("ACTIVE")  // ACTIVE | CANCELLED
  cancelledAt   DateTime?
  cancelledBy   String?   // User name who cancelled
  cancelReason  String?   // Reason for cancellation

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shopId, invoiceNumber])
  // Note: deletedAt index removed — Sale uses status-based cancellation
  @@index([userId])
  @@index([userId, date])
  @@index([userId, status])  // For filtering active/cancelled
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([customerId])
  
  // Compound indexes for optimized queries
  @@index([shopId, date, status])  // Sales list with date range + status filter
  @@index([shopId, status])        // Sales list filtered by status
  @@index([shopId, paymentStatus]) // G1: Filter by payment status
  @@index([shopId, channel])       // Sales channel filtering
}

model SaleItem {
  id          String   @id @default(cuid())

  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  salePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  profit      Decimal  @db.Decimal(10, 2)

  // G4: Item-level discount
  discountAmount Decimal @default(0) @db.Decimal(10, 2)  // ส่วนลดต่อชิ้น (บาท)

  // G3: Return tracking
  returnItems ReturnItem[]

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // @deprecated — use categoryRef (categoryId) instead. Kept for legacy data.
  categoryId  String?  // FK to LookupValue
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  date        DateTime @default(now())
  receiptUrl  String?

  // Ownership
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String   // Required for tenant isolation
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([shopId])  // RBAC index
  @@index([date])
  @@index([category])
  @@index([categoryId])
  
  // ✅ NEW: Compound indexes for optimized queries
  @@index([shopId, date])            // Expense reports with date range
  @@index([shopId, category, date])  // Filtered by category + date
}

// ==================== Income (รายรับที่เพิ่มเอง) ====================

model Income {
  id          String   @id @default(cuid())
  category    String   // @deprecated — use categoryRef (categoryId) instead. Kept for legacy data.
  categoryId  String?  // FK to LookupValue
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  date        DateTime @default(now())
  notes       String?
  receiptUrl  String?

  // Ownership
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId      String   // Required for tenant isolation
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  categoryRef LookupValue? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Soft Delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, date])
  @@index([shopId])
  @@index([date])
  @@index([category])
  @@index([categoryId])
  @@index([shopId, date])            // Income reports with date range
  @@index([shopId, category, date])  // Filtered by category + date
}


// ==================== Stock Management ====================

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  WASTE
  CANCEL
  SALE_CANCEL
  PURCHASE_CANCEL
}

model StockLog {
  id            String            @id @default(cuid())
  type          StockMovementType
  
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  
  quantity      Int
  balance       Int              // Balance snapshot after movement
  
  referenceId   String?           // @deprecated — use explicit saleId/purchaseId/returnId instead
  referenceType String?           // @deprecated — use StockMovementType enum instead

  // Explicit Relations for better integrity & reporting
  saleId        String?
  sale          Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  
  purchaseId    String?
  purchase      Purchase?         @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  
  returnId      String?           // G3: Link to return
  return        Return?           @relation(fields: [returnId], references: [id], onDelete: SetNull)

  note          String?
  
  date          DateTime          @default(now())
  
  // Ownership
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId        String            // Required for tenant isolation
  shop          Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt     DateTime          @default(now())

  @@index([productId, date])
  @@index([userId, date])
  @@index([shopId])  // RBAC index
  @@index([referenceId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([returnId])  // G3
}

// ==================== Returns (G3: คืนสินค้าบางส่วน) ====================

model Return {
  id              String       @id @default(cuid())
  returnNumber    String       // RET-00001 (auto-gen per shop)
  
  saleId          String
  sale            Sale         @relation(fields: [saleId], references: [id])
  
  reason          String       // เหตุผลการคืน
  refundAmount    Decimal      @db.Decimal(10, 2)  // ยอดคืนรวม
  refundMethod    String       // CASH | TRANSFER | CREDIT
  
  status          String       @default("COMPLETED")  // COMPLETED | CANCELLED
  
  // Ownership
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId          String
  shop            Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  items           ReturnItem[]
  stockLogs       StockLog[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@unique([shopId, returnNumber])
  @@index([shopId])
  @@index([saleId])
  @@index([shopId, createdAt])
}

model ReturnItem {
  id              String       @id @default(cuid())
  
  returnId        String
  return          Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  
  saleItemId      String
  saleItem        SaleItem     @relation(fields: [saleItemId], references: [id])
  
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  
  quantity        Int          // จำนวนที่คืน
  refundPerUnit   Decimal      @db.Decimal(10, 2)  // ราคาคืนต่อชิ้น (= net price)
  refundAmount    Decimal      @db.Decimal(10, 2)  // = refundPerUnit × quantity
  
  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
}

// ==================== Shipments ====================

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

model Shipment {
  id               String         @id @default(cuid())
  shipmentNumber   String         // SHP-00001 (race-safe auto-gen)

  // Link to Sale (1:1 enforced)
  saleId           String
  sale             Sale           @relation(fields: [saleId], references: [id])

  // Recipient
  recipientName    String         @db.VarChar(200)
  recipientPhone   String?        @db.VarChar(20)
  shippingAddress  String         @db.Text

  // Saved address (optional link)
  customerAddressId String?
  customerAddress   CustomerAddress? @relation(fields: [customerAddressId], references: [id])

  // Tracking
  trackingNumber   String?        @db.VarChar(100)
  shippingProvider String?        @db.VarChar(100)
  shippingCost     Decimal?       @db.Decimal(10, 2)

  // Status
  status           ShipmentStatus @default(PENDING)
  shippedAt        DateTime?
  deliveredAt      DateTime?
  notes            String?        @db.Text

  // Ownership
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId           String
  shop             Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([shopId, shipmentNumber])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([trackingNumber])
}

model CustomerAddress {
  id             String   @id @default(cuid())
  
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label          String?  @db.VarChar(50)   // "บ้าน", "ที่ทำงาน"
  recipientName  String   @db.VarChar(200)  // ชื่อผู้รับ
  phone          String?  @db.VarChar(20)
  address        String   @db.Text
  district       String?  @db.VarChar(100)
  subDistrict    String?  @db.VarChar(100)
  province       String?  @db.VarChar(100)
  postalCode     String?  @db.VarChar(10)
  isDefault      Boolean  @default(false)

  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shipments      Shipment[]

  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId])
  @@index([shopId])
}

// ==================== System Monitoring ====================

enum LogLevel {
  INFO
  WARN
  ERROR
}

model SystemLog {
  id          String   @id @default(cuid())
  level       LogLevel
  message     String
  stack       String?  @db.Text
  
  // Context
  path        String?
  method      String?
  body        String?  @db.Text
  
  // User Context (Optional)
  userId      String?
  userName    String?
  shopId      String?

  createdAt   DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@index([shopId])
}

// ==================== Notification System ====================

model Notification {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId      String?  // null = broadcast to all shop members
  type        String   // LOW_STOCK | NEW_SALE | PAYMENT_PENDING | RETURN_CREATED
  severity    String   @default("INFO")  // INFO | WARNING | CRITICAL
  title       String
  message     String
  link        String?  // Deep link e.g. /products/xxx
  metadata    Json?    // Extra context e.g. { productId, amount }
  isRead      Boolean  @default(false)
  readAt      DateTime?
  groupKey    String?  // Dedup key e.g. "LOW_STOCK:productId123"
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@unique([shopId, groupKey])
  @@index([shopId, userId, isRead, createdAt])
  @@index([shopId, createdAt])
}
