  member    ShopMember?           @relation(fields: [memberId], references: [id])
  lines     PurchaseReceiptLine[]
  stockLogs StockLog[]

  @@index([purchaseId])
  @@index([shopId])
  @@index([userId])
}

model PurchaseReceiptLine {
  id             String @id @default(cuid())
  receiptId      String
  purchaseItemId String
  productId      String
  quantity       Int // Received in this specific receipt
  warehouseId    String
  shopId         String

  receipt      PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseItem PurchaseItem    @relation(fields: [purchaseItemId], references: [id])
  product      Product         @relation(fields: [productId], references: [id])
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  shop         Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([purchaseItemId])
  @@index([productId])
  @@index([warehouseId])
}
