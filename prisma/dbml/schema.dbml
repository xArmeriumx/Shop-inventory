  }
}

Table PaymentAllocation {
  id String [pk]
  shopId String [not null]
  paymentId String [not null]
  documentType String [note: '── SSOT: Polymorphic Reference ──────────────────────────────────────
documentType: "INVOICE" | "SALE" | "PURCHASE" | "EXPENSE"
documentId:   FK ไปยัง Document ตาม documentType']
  documentId String
  amount Decimal [not null, note: '────────────────────────────────────────────────────────────────────']
  notes String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  invoiceId String [note: '⚠️  LEGACY FKs — Transition Period Only
จะลบออกใน Phase 4 หลัง Backfill + Monitor ครบ']
  purchaseId String
  expenseId String
  saleId String [note: '← เพิ่มกลับ (หายไปใน Schema เดิม)']
  expense Expense
  invoice Invoice
  payment Payment [not null]
  purchase Purchase
  sale Sale
  shop Shop [not null]

  Note: 'PaymentAllocation — Polymorphic Junction Table
Payment 1 ใบ สามารถ Allocate ไปยัง Document หลายใบได้
ใช้ documentType + documentId แทน nullable FK ทั้ง 4 ตัว'
}

