  invoiceId String [note: '⚠️  LEGACY FK — Transition Period Only
ใช้ PaymentAllocation.documentType + documentId แทน
จะลบออกใน Phase 4 หลัง Backfill ครบ 100%']
  saleId String
  purchaseId String
  expenseId String
  expense Expense
  invoice Invoice
  member ShopMember [not null]
  purchase Purchase
  sale Sale
  shop Shop [not null]
