//// ════════════════════════════════════════════════════════════════
//// Shop Inventory ERP — Clean Database Schema
//// ════════════════════════════════════════════════════════════════
//// เอกสารนี้ออกแบบมาเพื่อให้อ่านง่าย:
////   ✅ ลบ Virtual Relation Fields (Prisma-only) ออก → เหลือแค่ Column จริง
////   ✅ ลบเส้น Ref ที่เป็น "ใยแมงมุม" (Shop/User/ShopMember) ออก
////   ✅ เพิ่ม TableGroup แบ่งสี 7 โดเมน
////   ✅ เพิ่ม Note อธิบายภาษาไทยทุกตาราง
////
//// 📌 หมายเหตุ: ทุกตาราง (ยกเว้น User, SystemLog, AuditLog)
////    มี shopId เชื่อมกับ Shop เสมอ — ไม่แสดงเส้นเพื่อลดความรก
//// ════════════════════════════════════════════════════════════════

Project "Shop Inventory ERP" {
  database_type: 'PostgreSQL'
  Note: 'ระบบ ERP สำหรับร้านค้า — รองรับ Multi-tenant, Double Entry Accounting, Thai Tax Compliance'
}


//// ──────────────────────────────────────────────────
//// TABLE GROUPS (จัดกลุ่มตาราง 7 โดเมน)
//// ──────────────────────────────────────────────────

TableGroup iam [color: #3498db] {
  // 🔐 Identity & Access Management
  User
  Shop
  ShopMember
  Role
  OnboardingProgress
}

TableGroup master_data [color: #2ecc71] {
  // 📦 Master Data & Configuration
  Product
  LookupType
  LookupValue
  SupplierProduct
  DocSequence
}

TableGroup crm [color: #e67e22] {
  // 👥 CRM & Partners (SSOT Address)
  Customer
  Supplier
  PartnerAddress
  PartnerContact
  PartnerTaxProfile
}

TableGroup inventory [color: #9b59b6] {
  // 🏭 Inventory & Warehouse
  Warehouse
  WarehouseStock
  StockLog
  StockTransfer
  StockTransferLine
  StockTakeSession
  StockTakeItem
}

TableGroup sales [color: #e74c3c] {
  // 💰 Order-to-Cash (งานขาย)
  Quotation
  QuotationLine
  OrderRequest
  OrderRequestLine
  Sale
  SaleItem
  Invoice
  InvoiceLine
  DeliveryOrder
  DeliveryOrderLine
  Shipment
  Return
  ReturnItem
  ApprovalInstance
  ApprovalStep
}

TableGroup purchases [color: #f39c12] {
  // 🛒 Procure-to-Pay (งานจัดซื้อ)
  Purchase
  PurchaseItem
  PurchaseReceipt
  PurchaseReceiptLine
  PurchaseReturn
  PurchaseReturnItem
}

TableGroup finance [color: #1abc9c] {
  // 📊 Finance & Accounting
  Account
  JournalEntry
  JournalLine
  AccountingPeriod
  BankAccount
  BankStatement
  BankLine
  Payment
  PaymentAllocation
  Expense
  Income
}

TableGroup tax [color: #c0392b] {
  // 🧾 Thai Tax Compliance
  TaxCode
  CompanyTaxProfile
  ProductTaxProfile
  SalesTaxEntry
  PurchaseTaxEntry
  PurchaseTaxDocument
  PurchaseTaxDocumentLink
  PurchaseTaxLine
  WhtCode
  WhtEntry
  WhtCertificate
}

TableGroup system [color: #7f8c8d] {
  // ⚙️ System & Audit
  SystemLog
  AuditLog
  Notification
}


//// 📋 User: ผู้ใช้งานระบบ (Login Account)
Table User {
  id String [pk]
  email String [unique, not null]
  name String
  password String
  image String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  lastActiveAt DateTime [default: `now()`, not null]
  sessionVersion Int [not null, default: 1]
}

//// 📋 LookupType: ประเภทค่าคงที่ (หมวดหมู่, หน่วยนับ)
Table LookupType {
  id String [pk]
  code LookupTypeCode [unique, not null]
  name String [not null]
  description String
  isSystem Boolean [not null, default: false]
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 LookupValue: ค่าคงที่ในระบบ (สินค้า, ค่าใช้จ่าย)
Table LookupValue {
  id String [pk]
  lookupTypeId String [not null]
  userId String
  code String [not null]
  name String [not null]
  color String
  icon String
  order Int [not null, default: 0]
  isActive Boolean [not null, default: true]
  isDefault Boolean [not null, default: false]
  isSystem Boolean [not null, default: false]
  metadata Json
  deletedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  shopId String

  indexes {
    (lookupTypeId, shopId, code) [unique]
  }
}

//// 📋 Shop: ร้านค้า/บริษัท — ศูนย์กลาง Multi-tenancy
Table Shop {
  id String [pk]
  name String [not null]
  address String
  phone String
  logo String
  taxId String
  userId String [unique, not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  invoicePrefix String [default: 'INV']
  promptPayId String
  latitude Float
  longitude Float
  defaultCurrency String [not null, default: 'THB']
  fiscalYearStart Int [not null, default: 1]
  genesisStep Int [not null, default: 1]
  industryType String
  legalEntityName String
  onboardingCompletedAt DateTime
  onboardingMode String
  setupCompletedAt DateTime
  signatoryName String
  signatoryTitle String
  shippingConfig Json
  salesFlowMode SalesFlowMode [not null, default: 'RETAIL']
  inventoryMode InventoryMode [not null, default: 'SIMPLE']
}

//// 📋 OnboardingProgress: สถานะการตั้งค่าระบบเริ่มต้น
Table OnboardingProgress {
  id String [pk]
  shopId String [unique, not null]
  wizardDraft Json
  wizardVersion Int [not null, default: 1]
  tutorialTrack Int [not null, default: 0]
  tutorialStep Int [not null, default: 0]
  tutorialDismissed Boolean [not null, default: false]
  dismissedSetupItems String[] [not null]
  lastSetupViewedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 Role: บทบาท (Admin, Staff, etc.)
Table Role {
  id String [pk]
  name String [not null]
  description String
  isDefault Boolean [not null, default: false]
  isSystem Boolean [not null, default: false]
  shopId String [not null]
  permissions Permission[] [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, name) [unique]
  }
}

//// 📋 ShopMember: สมาชิกร้านค้า — เชื่อม User กับ Shop + Role
Table ShopMember {
  id String [pk]
  userId String [not null]
  shopId String [not null]
  roleId String [not null]
  isOwner Boolean [not null, default: false]
  joinedAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  permissionVersion Int [not null, default: 1]
  departmentCode String
  regionIds String[] [not null]

  indexes {
    (userId, shopId) [unique]
  }
}

//// 📋 Product: สินค้า — Master Data หลัก
Table Product {
  id String [pk]
  name String [not null]
  description String
  sku String
  category String [not null]
  costPrice Decimal [not null]
  salePrice Decimal [not null]
  stock Int [not null, default: 0]
  minStock Int [not null, default: 5]
  images String[] [not null]
  isActive Boolean [not null, default: true]
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  deletedAt DateTime
  categoryId String
  shopId String [not null]
  isLowStock Boolean [not null, default: false]
  supplierId String
  version Int [not null, default: 1]
  avgLeadTime Int
  isSaleable Boolean [not null, default: true]
  metadata Json
  moq Int
  reservedStock Int [not null, default: 0]
  packagingQty Int [not null, default: 1]
  memberId String

  indexes {
    (shopId, sku) [unique]
  }
}

//// 📋 Warehouse: คลังสินค้า (รองรับหลายคลัง)
Table Warehouse {
  id String [pk]
  name String [not null]
  code String [not null]
  address String
  isDefault Boolean [not null, default: false]
  isActive Boolean [not null, default: true]
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, code) [unique]
  }
}

//// 📋 WarehouseStock: ยอดสินค้าแยกตามคลัง (Bridge Table)
Table WarehouseStock {
  id String [pk]
  productId String [not null]
  warehouseId String [not null]
  shopId String [not null]
  quantity Int [not null, default: 0]
  reservedStock Int [not null, default: 0]
  minStock Int
  binLocation String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (productId, warehouseId) [unique]
  }
}

//// 📋 StockTransfer: ใบโอนสินค้าข้ามคลัง
Table StockTransfer {
  id String [pk]
  transferNo String [not null]
  status TransferStatus [not null, default: 'DRAFT']
  transferDate DateTime [default: `now()`, not null]
  fromWarehouseId String [not null]
  toWarehouseId String [not null]
  notes String
  shopId String [not null]
  memberId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, transferNo) [unique]
  }
}

//// 📋 StockTransferLine: รายการสินค้าในใบโอน
Table StockTransferLine {
  id String [pk]
  transferId String [not null]
  productId String [not null]
  quantity Int [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 Supplier: ผู้จำหน่าย/Vendor
Table Supplier {
  id String [pk]
  name String [not null]
  phone String
  address String
  notes String
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  deletedAt DateTime
  shopId String [not null]
  code String
  contactName String
  email String
  taxId String
  groupCode String
  moq Decimal
  purchaseNote String
  latitude Float
  longitude Float
  creditLimit Decimal
  creditTerm Int
  paymentTerms String
}

//// 📋 Customer: ลูกค้า
Table Customer {
  id String [pk]
  name String [not null]
  phone String
  address String
  notes String
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  deletedAt DateTime
  taxId String
  shopId String [not null]
  email String
  creditLimit Decimal
  creditTerm Int
  groupCode String
  region String
  latitude Float
  longitude Float
  billingAddress String
  shippingAddress String
}

//// 📋 Purchase: ใบสั่งซื้อ (PO)
Table Purchase {
  id String [pk]
  date DateTime [default: `now()`, not null]
  supplierId String
  totalCost Decimal [not null]
  receiptUrl String
  notes String
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  supplierName String
  cancelReason String
  cancelledAt DateTime
  cancelledBy String
  status String [not null, default: 'ACTIVE']
  shopId String [not null]
  purchaseNumber String
  paymentMethod String [not null, default: 'CASH']
  docType String [not null, default: 'ORDER']
  linkedPRId String
  purchaseType String [not null, default: 'LOCAL']
  requestNumber String
  receivedAt DateTime
  receivedBy String
  memberId String
  paidAmount Decimal [not null, default: 0]
  paymentStatus String [not null, default: 'UNPAID']
  residualAmount Decimal [not null, default: 0]

  indexes {
    (shopId, purchaseNumber) [unique]
  }
}

//// 📋 PurchaseItem: รายการสินค้าใน PO
Table PurchaseItem {
  id String [pk]
  purchaseId String [not null]
  productId String [not null]
  quantity Int [not null]
  receivedQuantity Int [not null, default: 0]
  costPrice Decimal [not null]
  subtotal Decimal [not null]
  packagingQty Int [not null, default: 1]
}

//// 📋 Sale: บิลขาย — จุดรวมรายได้หลัก
Table Sale {
  id String [pk]
  invoiceNumber String [not null]
  date DateTime [default: `now()`, not null]
  customerId String
  customerName String
  customerAddress String
  customerPhone String
  totalAmount Decimal [not null]
  totalCost Decimal [not null]
  profit Decimal [not null]
  paymentMethod String [not null]
  notes String
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  receiptUrl String
  cancelReason String
  cancelledAt DateTime
  cancelledBy String
  status String [not null, default: 'ACTIVE']
  shopId String [not null]
  discountAmount Decimal [not null, default: 0]
  discountType String
  discountValue Decimal
  netAmount Decimal [not null, default: 0]
  paymentNote String
  paymentProof String
  paymentVerifiedAt DateTime
  paymentVerifiedBy String
  channel String [not null, default: 'WALK_IN']
  taxMode String [not null, default: 'INCLUSIVE']
  taxRate Decimal [not null, default: 7]
  taxAmount Decimal [not null, default: 0]
  taxableAmount Decimal [not null, default: 0]
  billingStatus String [not null, default: 'UNBILLED']
  bookingStatus String [not null, default: 'NONE']
  deliveryStatus String [not null, default: 'PENDING']
  departmentCode String
  isLocked Boolean [not null, default: false]
  memberId String
  paidAmount Decimal [not null, default: 0]
  paymentStatusProof String [not null, default: 'VERIFIED']
  residualAmount Decimal [not null, default: 0]
  paymentStatus DocPaymentStatus [not null, default: 'UNPAID']
  editLockStatus String [not null, default: 'NONE']
  lockReason String
  orderRequestId String
  quotationId String

  indexes {
    (shopId, invoiceNumber) [unique]
  }
}

//// 📋 SaleItem: รายการสินค้าในบิลขาย
Table SaleItem {
  id String [pk]
  saleId String [not null]
  productId String [not null]
  quantity Int [not null]
  salePrice Decimal [not null]
  costPrice Decimal [not null]
  subtotal Decimal [not null]
  profit Decimal [not null]
  discountAmount Decimal [not null, default: 0]
  taxAmount Decimal [not null, default: 0]
  taxableAmount Decimal [not null, default: 0]
  packagingQty Int [not null, default: 1]
  warehouseId String
}

//// 📋 Expense: รายจ่ายทั่วไป
Table Expense {
  id String [pk]
  category String [not null]
  amount Decimal [not null]
  description String
  date DateTime [default: `now()`, not null]
  receiptUrl String
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  deletedAt DateTime
  categoryId String
  shopId String [not null]
  memberId String
  paidAmount Decimal [not null, default: 0]
  paymentStatus String [not null, default: 'UNPAID']
  residualAmount Decimal [not null, default: 0]
}

//// 📋 Income: รายได้อื่นๆ
Table Income {
  id String [pk]
  category String [not null]
  categoryId String
  amount Decimal [not null]
  description String
  date DateTime [default: `now()`, not null]
  notes String
  receiptUrl String
  userId String [not null]
  shopId String [not null]
  deletedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String
}

//// 📋 StockLog: ประวัติการเคลื่อนไหวสต็อก (Event Log)
Table StockLog {
  id String [pk]
  type StockMovementType [not null]
  productId String [not null]
  quantity Int [not null]
  balance Int [not null]
  referenceId String
  referenceType String
  note String
  warehouseId String
  warehouseBalance Int
  date DateTime [default: `now()`, not null]
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  shopId String [not null]
  purchaseId String
  purchaseReceiptId String
  saleId String
  returnId String
  memberId String
  stockTakeItemId String
  stockTakeSessionId String
  deliveryOrderId String
  purchaseReturnId String
}

//// 📋 Return: ใบรับคืนสินค้า (ฝั่งขาย)
Table Return {
  id String [pk]
  returnNumber String [not null]
  saleId String [not null]
  reason String [not null]
  refundAmount Decimal [not null]
  refundMethod String [not null]
  status String [not null, default: 'COMPLETED']
  userId String [not null]
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String

  indexes {
    (shopId, returnNumber) [unique]
  }
}

//// 📋 ReturnItem: รายการสินค้าที่รับคืน
Table ReturnItem {
  id String [pk]
  returnId String [not null]
  saleItemId String [not null]
  productId String [not null]
  quantity Int [not null]
  warehouseId String
  refundPerUnit Decimal [not null]
  refundAmount Decimal [not null]
}

//// 📋 PurchaseReturn: ใบส่งคืนสินค้า (ฝั่งจัดซื้อ)
Table PurchaseReturn {
  id String [pk]
  returnNumber String [not null]
  purchaseId String [not null]
  reason String [not null]
  recoveryAmount Decimal [not null]
  recoveryMethod String [not null]
  status String [not null, default: 'COMPLETED']
  userId String [not null]
  shopId String [not null]
  memberId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, returnNumber) [unique]
  }
}

//// 📋 PurchaseReturnItem: รายการสินค้าที่ส่งคืน Vendor
Table PurchaseReturnItem {
  id String [pk]
  purchaseReturnId String [not null]
  purchaseItemId String [not null]
  productId String [not null]
  quantity Int [not null]
  recoveryPerUnit Decimal [not null]
  recoveryAmount Decimal [not null]
}

//// 📋 Shipment: ข้อมูลการจัดส่ง + Tracking
Table Shipment {
  id String [pk]
  shipmentNumber String [not null]
  saleId String [not null]
  recipientName String [not null]
  recipientPhone String
  shippingAddress String [not null]
  trackingNumber String
  shippingProvider String
  shippingCost Decimal
  status ShipmentStatus [not null, default: 'PENDING']
  shippedAt DateTime
  deliveredAt DateTime
  notes String
  userId String [not null]
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  dispatchSeq Int
  latitude Float
  longitude Float
  memberId String
  partnerAddressId String

  indexes {
    (shopId, shipmentNumber) [unique]
  }
}

//// 📋 PartnerAddress: ที่อยู่คู่ค้า (SSOT — ใช้ร่วม Customer+Supplier)
Table PartnerAddress {
  id String [pk]
  customerId String
  supplierId String
  label String
  recipientName String
  phone String
  email String
  address String [not null]
  district String
  subDistrict String
  province String
  postalCode String
  taxId String
  isDefaultBilling Boolean [not null, default: false]
  isDefaultShipping Boolean [not null, default: false]
  latitude Float
  longitude Float
  shopId String [not null]
  deletedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 PartnerContact: ผู้ติดต่อภายใต้ที่อยู่
Table PartnerContact {
  id String [pk]
  partnerAddressId String [not null]
  name String [not null]
  position String
  phone String
  email String
  lineId String
  isPrimary Boolean [not null, default: false]
  notes String
  shopId String [not null]
  deletedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 SystemLog: บันทึก Error/Info ของระบบ
Table SystemLog {
  id String [pk]
  level LogLevel [not null]
  message String [not null]
  stack String
  path String
  method String
  body String
  userId String
  userName String
  shopId String
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 Notification: การแจ้งเตือนผู้ใช้
Table Notification {
  id String [pk]
  shopId String [not null]
  userId String
  type String [not null]
  severity String [not null, default: 'INFO']
  title String [not null]
  message String [not null]
  link String
  metadata Json
  isRead Boolean [not null, default: false]
  readAt DateTime
  groupKey String
  createdAt DateTime [default: `now()`, not null]
  expiresAt DateTime

  indexes {
    (shopId, groupKey) [unique]
  }
}

//// 📋 DocSequence: ระบบรันเลขที่เอกสาร (Atomic Counter)
Table DocSequence {
  id String [pk]
  shopId String [not null]
  prefix String [not null]
  year Int [not null]
  month Int [not null]
  counter Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, prefix, year, month) [unique]
  }
}

//// 📋 AuditLog: ประวัติการแก้ไขข้อมูล (Before/After Snapshot)
Table AuditLog {
  id String [pk]
  shopId String
  action String [not null]
  note String
  createdAt DateTime [default: `now()`, not null]
  actorUserId String
  afterSnapshot Json
  beforeSnapshot Json
  changedFields String[] [not null]
  reason String
  status String [not null, default: 'SUCCESS']
  targetId String
  targetType String
  actorEmail String
  actorName String
}

//// 📋 SupplierProduct: แคตตาล็อกสินค้าของ Vendor (ราคา, MOQ, Lead Time)
Table SupplierProduct {
  id String [pk]
  shopId String [not null]
  supplierId String [not null]
  productId String [not null]
  moq Int [default: 0]
  vendorPrice Decimal
  vendorSku String
  notes String
  deletedAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  leadTime Int [default: 0]

  indexes {
    (supplierId, productId) [unique]
  }
}

//// 📋 ApprovalInstance: กระบวนการอนุมัติ (Generic Workflow)
Table ApprovalInstance {
  id String [pk]
  shopId String [not null]
  documentType String [not null]
  documentId String [not null]
  status ApprovalStatus [not null, default: 'PENDING']
  currentLevel Int [not null, default: 1]
  saleId String
  purchaseId String
  orderRequestId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 ApprovalStep: ขั้นตอนอนุมัติแต่ละระดับ
Table ApprovalStep {
  id String [pk]
  approvalInstanceId String [not null]
  level Int [not null, default: 1]
  approverUserId String [not null]
  status ApprovalStatus [not null, default: 'PENDING']
  actionAt DateTime
  reason String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 DeliveryOrder: ใบสั่งจัดส่งสินค้า
Table DeliveryOrder {
  id String [pk]
  deliveryNo String [not null]
  saleId String [not null]
  status DeliveryStatus [not null, default: 'WAITING']
  scheduledDate DateTime
  deliveredAt DateTime
  notes String
  userId String [not null]
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String

  indexes {
    (shopId, deliveryNo) [unique]
  }
}

//// 📋 DeliveryOrderLine: รายการสินค้าในใบจัดส่ง
Table DeliveryOrderLine {
  id String [pk]
  deliveryOrderId String [not null]
  productId String [not null]
  quantity Int [not null]
  pickedQty Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 Quotation: ใบเสนอราคา
Table Quotation {
  id String [pk]
  quotationNo String [not null]
  customerId String [not null]
  customerAddressSnapshot String
  customerPhoneSnapshot String
  salespersonId String
  status QuotationStatus [not null, default: 'DRAFT']
  date DateTime [default: `now()`, not null]
  validUntil DateTime
  currencyCode String [not null, default: 'THB']
  totalAmount Decimal [not null]
  notes String
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String
  taxMode String [not null, default: 'INCLUSIVE']
  taxRate Decimal [not null, default: 7]
  taxAmount Decimal [not null, default: 0]
  taxableAmount Decimal [not null, default: 0]

  indexes {
    (shopId, quotationNo) [unique]
  }
}

//// 📋 QuotationLine: รายการสินค้าในใบเสนอราคา
Table QuotationLine {
  id String [pk]
  quotationId String [not null]
  productId String [not null]
  description String
  quantity Int [not null]
  unitPrice Decimal [not null]
  discount Decimal [not null, default: 0]
  subtotal Decimal [not null]
  taxAmount Decimal [not null, default: 0]
  taxableAmount Decimal [not null, default: 0]
  sortOrder Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 OrderRequest: ใบสั่งขาย/คำขอสั่งซื้อภายใน
Table OrderRequest {
  id String [pk]
  requestNo String [not null]
  requesterId String [not null]
  status OrderRequestStatus [not null, default: 'DRAFT']
  date DateTime [default: `now()`, not null]
  notes String
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String
  quotationId String

  indexes {
    (shopId, requestNo) [unique]
  }
}

//// 📋 OrderRequestLine: รายการสินค้าในใบสั่งขาย
Table OrderRequestLine {
  id String [pk]
  orderRequestId String [not null]
  productId String
  description String
  quantity Int [not null]
  uom String
  sortOrder Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 Invoice: ใบกำกับภาษี/ใบแจ้งหนี้ (มี Snapshot)
Table Invoice {
  id String [pk]
  invoiceNo String [not null]
  saleId String [unique, not null]
  customerId String
  status InvoiceStatus [not null, default: 'DRAFT']
  date DateTime [default: `now()`, not null]
  dueDate DateTime
  currencyCode String [not null, default: 'THB']
  totalAmount Decimal [not null]
  residualAmount Decimal [not null, default: 0]
  notes String
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  memberId String
  paidAmount Decimal [not null, default: 0]
  paymentStatus DocPaymentStatus [not null, default: 'UNPAID']
  billingAddressSnapshot String [not null]
  customerNameSnapshot String [not null]
  discountAmount Decimal [not null, default: 0]
  netAmount Decimal [not null, default: 0]
  paymentTermSnapshot String
  shippingAddressSnapshot String
  subtotalAmount Decimal [not null, default: 0]
  taxAmount Decimal [not null, default: 0]
  taxIdSnapshot String
  editLockStatus String [not null, default: 'NONE']
  lockReason String
  customerBranchSnapshot String
  isTaxInvoice Boolean [not null, default: false]
  postedAt DateTime
  sellerAddressSnapshot String [not null, default: '']
  sellerBranchSnapshot String
  sellerNameSnapshot String [not null, default: '']
  sellerTaxIdSnapshot String
  taxCalculationModeSnapshot String [not null, default: 'EXCLUSIVE']
  taxCodeSnapshot String
  taxPostingStatus String
  taxRateSnapshot Decimal [not null, default: 0]
  taxReportMonth Int
  taxReportYear Int
  taxableBaseAmount Decimal [not null, default: 0]

  indexes {
    (shopId, invoiceNo) [unique]
  }
}

//// 📋 InvoiceLine: รายการสินค้าในใบกำกับภาษี (มี Snapshot)
Table InvoiceLine {
  id String [pk]
  invoiceId String [not null]
  productId String [not null]
  description String
  quantity Int [not null]
  unitPrice Decimal [not null]
  subtotal Decimal [not null]
  sortOrder Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
  descriptionSnapshot String
  discountAmount Decimal [not null, default: 0]
  lineNetAmount Decimal [not null, default: 0]
  lineSubtotalAmount Decimal [not null, default: 0]
  productNameSnapshot String [not null]
  skuSnapshot String
  taxAmount Decimal [not null, default: 0]
  taxCodeSnapshot String
  taxRateSnapshot Decimal [not null, default: 0]
  uomSnapshot String
  taxableBaseAmount Decimal [not null, default: 0]
}

//// 📋 Payment: การรับ/จ่ายเงิน
Table Payment {
  id String [pk]
  shopId String [not null]
  memberId String [not null]
  invoiceId String
  saleId String
  type PaymentType [not null, default: 'IN']
  amount Decimal [not null]
  currency String [not null, default: 'THB']
  paymentDate DateTime [default: `now()`, not null]
  paymentMethodCode String [not null]
  referenceId String
  note String
  status PaymentStatus [not null, default: 'POSTED']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  expenseId String
  purchaseId String
  paymentNo String

  indexes {
    (shopId, paymentNo) [unique]
  }
}

//// 📋 PaymentAllocation: การตัดยอดชำระ (1 Payment → N เอกสาร)
Table PaymentAllocation {
  id String [pk]
  shopId String [not null]
  paymentId String [not null]
  invoiceId String
  purchaseId String
  expenseId String
  amount Decimal [not null]
  notes String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 StockTakeSession: รอบการตรวจนับสต็อก
Table StockTakeSession {
  id String [pk]
  shopId String [not null]
  status StockTakeStatus [not null, default: 'DRAFT']
  notes String
  createdByMemberId String [not null]
  submittedByMemberId String
  submittedAt DateTime
  completedByMemberId String
  completedAt DateTime
  cancelledByMemberId String
  cancelledAt DateTime
  cancelReason String
  warehouseId String
  locationId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 StockTakeItem: รายการสินค้าที่ตรวจนับ
Table StockTakeItem {
  id String [pk]
  sessionId String [not null]
  productId String [not null]
  systemOnHandQty Int [not null]
  countedQty Int
  differenceQty Int [not null, default: 0]
  isCounted Boolean [not null, default: false]
  countedAt DateTime
  note String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 TaxCode: รหัสภาษี (VAT 7%, Exempt)
Table TaxCode {
  id String [pk]
  shopId String [not null]
  code String [not null]
  name String [not null]
  description String
  direction TaxDirection [not null]
  kind TaxKind [not null]
  rate Decimal [not null]
  calculationMode TaxCalculationMode [not null, default: 'EXCLUSIVE']
  isActive Boolean [not null, default: true]
  effectiveFrom DateTime [not null]
  effectiveTo DateTime
  reportBucket String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, code) [unique]
  }
}

//// 📋 CompanyTaxProfile: ข้อมูลภาษีของบริษัทเรา
Table CompanyTaxProfile {
  id String [pk]
  shopId String [unique, not null]
  isVatRegistered Boolean [not null, default: false]
  vatRegistrationDate DateTime
  vatThreshold Decimal
  legalName String [not null]
  taxPayerId String
  branchCode String
  registeredAddress String
  defaultSalesTaxCode String
  defaultPurchaseTaxCode String
  taxInvoicePrefix String
  creditNotePrefix String
  debitNotePrefix String
  isTaxInvoiceFull Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  authorizedPerson String
  authorizedPosition String
}

//// 📋 PartnerTaxProfile: ข้อมูลภาษีของคู่ค้า
Table PartnerTaxProfile {
  id String [pk]
  shopId String [not null]
  customerId String [unique]
  supplierId String [unique]
  taxId String
  branchCode String
  branchName String
  isVatRegistrant Boolean [not null, default: false]
  defaultSalesTaxCode String
  defaultPurchaseTaxCode String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  defaultWhtCodeId String
  isSubjectToWht Boolean [not null, default: false]
  payeeType WhtPayeeType [not null, default: 'UNKNOWN']
}

//// 📋 ProductTaxProfile: ข้อมูลภาษีของสินค้า
Table ProductTaxProfile {
  id String [pk]
  shopId String [not null]
  productId String [unique, not null]
  taxClass ProductTaxClass [not null, default: 'TAXABLE']
  salesTaxCode String
  purchaseTaxCode String
  isAlwaysExempt Boolean [not null, default: false]
  exemptReason String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 SalesTaxEntry: สมุดรายงานภาษีขาย (ภ.พ.30)
Table SalesTaxEntry {
  id String [pk]
  shopId String [not null]
  sourceType String [not null]
  sourceId String [unique, not null]
  taxMonth Int [not null]
  taxYear Int [not null]
  partnerId String
  partnerName String
  taxCode String
  taxRate Decimal [not null]
  taxableBaseAmount Decimal [not null]
  taxAmount Decimal [not null]
  postingStatus TaxPostingStatus [not null, default: 'DRAFT']
  postedAt DateTime
  voidedAt DateTime
  postedBy String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 PurchaseTaxEntry: สมุดรายงานภาษีซื้อ (ภ.พ.30)
Table PurchaseTaxEntry {
  id String [pk]
  shopId String [not null]
  sourceType String [not null]
  sourceId String [unique, not null]
  taxMonth Int [not null]
  taxYear Int [not null]
  vendorDocNo String
  vendorDocDate DateTime
  partnerId String
  partnerName String
  taxCode String
  taxRate Decimal [not null]
  taxableBaseAmount Decimal [not null]
  taxAmount Decimal [not null]
  postingStatus TaxPostingStatus [not null, default: 'DRAFT']
  postedAt DateTime
  voidedAt DateTime
  postedBy String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  claimStatus ClaimStatus [not null, default: 'CLAIMABLE']
}

//// 📋 PurchaseTaxDocument: เอกสารภาษีฝั่งจัดซื้อ
Table PurchaseTaxDocument {
  id String [pk]
  shopId String [not null]
  memberId String [not null]
  postedByMemberId String
  voidedByMemberId String
  postedAt DateTime
  voidedAt DateTime
  sourceType PurchaseTaxSourceType [not null, default: 'PURCHASE_ORDER']
  supplierId String
  vendorNameSnapshot String [not null]
  vendorAddressSnapshot String
  vendorTaxIdSnapshot String
  vendorBranchSnapshot String
  vendorDocNo String [not null]
  vendorDocDate DateTime [not null]
  internalDocNo String [not null]
  isVatDocument Boolean [not null, default: true]
  taxCodeSnapshot String
  taxRateSnapshot Decimal [not null, default: 0]
  taxCalculationMode TaxCalculationMode [not null, default: 'EXCLUSIVE']
  subtotalAmount Decimal [not null]
  discountAmount Decimal [not null, default: 0]
  taxableBaseAmount Decimal [not null]
  taxAmount Decimal [not null]
  netAmount Decimal [not null]
  status PurchaseTaxStatus [not null, default: 'DRAFT']
  claimStatus ClaimStatus [not null, default: 'CLAIMABLE']
  claimReason String
  notes String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, internalDocNo) [unique]
  }
}

//// 📋 PurchaseTaxDocumentLink: เชื่อม Tax Doc กับ PO
Table PurchaseTaxDocumentLink {
  id String [pk]
  purchaseTaxDocumentId String [not null]
  purchaseOrderId String [not null]
  allocatedAmount Decimal
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (purchaseTaxDocumentId, purchaseOrderId) [unique]
  }
}

//// 📋 PurchaseTaxLine: รายการสินค้าในเอกสารภาษีซื้อ
Table PurchaseTaxLine {
  id String [pk]
  documentId String [not null]
  productNameSnapshot String [not null]
  skuSnapshot String
  uomSnapshot String
  taxCodeSnapshot String
  taxRateSnapshot Decimal [not null]
  description String
  quantity Decimal [not null]
  unitPrice Decimal [not null]
  discountAmount Decimal [not null, default: 0]
  taxableBaseAmount Decimal [not null]
  taxAmount Decimal [not null]
  lineNetAmount Decimal [not null]
}

//// 📋 WhtCode: รหัสหัก ณ ที่จ่าย
Table WhtCode {
  id String [pk]
  shopId String [not null]
  code String [not null]
  name String [not null]
  rate Decimal [not null]
  formType WhtFormType [not null]
  payeeType WhtPayeeType [not null, default: 'ANY']
  incomeCategory String
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, code) [unique]
  }
}

//// 📋 WhtEntry: รายการหัก ณ ที่จ่าย
Table WhtEntry {
  id String [pk]
  shopId String [not null]
  memberId String
  paymentId String [unique]
  partnerId String
  payeeNameSnapshot String [not null]
  payeeTaxIdSnapshot String
  payeeBranchSnapshot String
  payeeTypeSnapshot WhtPayeeType [not null]
  whtCodeId String
  formTypeSnapshot WhtFormType [not null]
  incomeCategorySnapshot String
  rateSnapshot Decimal [not null]
  grossPayableAmount Decimal [not null]
  whtBaseAmount Decimal [not null]
  whtAmount Decimal [not null]
  netPaidAmount Decimal [not null]
  paymentDate DateTime [not null]
  taxMonth Int [not null]
  taxYear Int [not null]
  status TaxPostingStatus [not null, default: 'DRAFT']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  purchaseId String
}

//// 📋 WhtCertificate: หนังสือรับรองหัก ณ ที่จ่าย (50 ทวิ)
Table WhtCertificate {
  id String [pk]
  shopId String [not null]
  whtEntryId String [unique, not null]
  certificateNo String [not null]
  issueDate DateTime [not null]
  payerNameSnapshot String [not null]
  payerTaxIdSnapshot String
  payerBranchSnapshot String
  payerAddressSnapshot String
  payeeNameSnapshot String [not null]
  payeeTaxIdSnapshot String
  payeeBranchSnapshot String
  payeeAddressSnapshot String
  status TaxPostingStatus [not null, default: 'DRAFT']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, certificateNo) [unique]
  }
}

//// 📋 Account: ผังบัญชี (Chart of Accounts) — Self-referencing Hierarchy
Table Account {
  id String [pk]
  shopId String [not null]
  code String [not null]
  name String [not null]
  category AccountCategory [not null]
  normalBalance NormalBalance [not null]
  parentId String
  isPostable Boolean [not null, default: true]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  children Account [not null]

  indexes {
    (shopId, code) [unique]
  }
}

//// 📋 JournalEntry: สมุดรายวัน (Double Entry Ledger)
Table JournalEntry {
  id String [pk]
  shopId String [not null]
  entryNo String [not null]
  journalDate DateTime [not null]
  description String
  status JournalStatus [not null, default: 'DRAFT']
  postedAt DateTime
  sourceType String
  sourceId String
  sourceNo String
  memberId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  postingPurpose String [not null, default: 'GENERAL']

  indexes {
    (shopId, entryNo) [unique]
    (shopId, sourceType, sourceId, postingPurpose) [unique]
  }
}

//// 📋 JournalLine: รายการเดบิต/เครดิต
Table JournalLine {
  id String [pk]
  journalEntryId String [not null]
  accountId String [not null]
  description String
  debitAmount Decimal [not null, default: 0]
  creditAmount Decimal [not null, default: 0]
  partnerId String
  partnerType String
  referenceType String
  referenceId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  bankLineId String
  reconcileStatus String [not null, default: 'UNRECONCILED']
  reconciledAt DateTime
  referenceNo String
}

//// 📋 AccountingPeriod: รอบระยะเวลาบัญชี (เปิด/ปิดงบ)
Table AccountingPeriod {
  id String [pk]
  shopId String [not null]
  periodName String [not null]
  startDate DateTime [not null]
  endDate DateTime [not null]
  status PeriodStatus [not null, default: 'OPEN']
  closedAt DateTime
  closedByMemberId String
  reopenedAt DateTime
  reopenedByMemberId String
  reopenReason String
  history Json
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, startDate, endDate) [unique]
  }
}

//// 📋 BankAccount: บัญชีธนาคาร
Table BankAccount {
  id String [pk]
  name String [not null]
  bankName String [not null]
  accountNo String [not null]
  currency String [not null, default: 'THB']
  isActive Boolean [not null, default: true]
  glAccountId String [not null]
  shopId String [not null]
  userId String [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, accountNo) [unique]
  }
}

//// 📋 BankStatement: รายการเดินบัญชี (Statement)
Table BankStatement {
  id String [pk]
  bankAccountId String [not null]
  statementDate DateTime [default: `now()`, not null]
  periodStart DateTime
  periodEnd DateTime
  openingBalance Decimal [not null, default: 0]
  closingBalance Decimal [not null, default: 0]
  importSource String [not null, default: 'MANUAL']
  status String [not null, default: 'DRAFT']
  shopId String [not null]
  memberId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 BankLine: แต่ละรายการใน Statement (Reconciliation)
Table BankLine {
  id String [pk]
  statementId String [not null]
  bookingDate DateTime [not null]
  valueDate DateTime
  description String
  referenceNo String
  debitAmount Decimal [not null, default: 0]
  creditAmount Decimal [not null, default: 0]
  netAmount Decimal [not null]
  balanceAfter Decimal
  matchStatus BankLineMatchStatus [not null, default: 'UNMATCHED']
  matchedAt DateTime
  matchedByMemberId String
  dedupeHash String
  shopId String [not null]
  createdAt DateTime [default: `now()`, not null]
}

//// 📋 PurchaseReceipt: ใบรับสินค้าเข้าคลัง (GR)
Table PurchaseReceipt {
  id String [pk]
  shopId String [not null]
  purchaseId String [not null]
  receiptNumber String [not null]
  receivedDate DateTime [default: `now()`, not null]
  notes String
  status String [not null, default: 'COMPLETED']
  userId String [not null]
  memberId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
}

//// 📋 PurchaseReceiptLine: รายการสินค้าที่รับเข้าคลัง
Table PurchaseReceiptLine {
  id String [pk]
  receiptId String [not null]
  purchaseItemId String [not null]
  productId String [not null]
  quantity Int [not null]
  warehouseId String [not null]
  shopId String [not null]
}

//// 📋 CustomerToShopMember: ตารางเชื่อม Customer กับ Salesperson
Table CustomerToShopMember {
  customersId String [ref: > Customer.id]
  salespersonsId String [ref: > ShopMember.id]
}


//// ══════════════════════════════════════
//// ENUMS (ค่าคงที่ของระบบ)
//// ══════════════════════════════════════

Enum InventoryMode {
  SIMPLE
  SINGLE
  MULTI
}

Enum LookupTypeCode {
  PRODUCT_CATEGORY
  EXPENSE_CATEGORY
  PAYMENT_METHOD
  UNIT
  INCOME_CATEGORY
}

Enum Permission {
  PRODUCT_VIEW
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
  PRODUCT_VIEW_COST
  SALE_VIEW
  SALE_CREATE
  SALE_UPDATE
  SALE_CANCEL
  SALE_VOID
  SALE_VIEW_PROFIT
  SALE_EDIT_LOCKED
  INVOICE_VIEW
  INVOICE_CREATE
  INVOICE_POST
  INVOICE_CANCEL
  INVOICE_MANAGE
  FINANCE_VIEW_LEDGER
  FINANCE_PAYMENT_VOID
  FINANCE_MANAGE_CREDIT
  STOCK_VIEW_HISTORY
  STOCK_ADJUST
  STOCK_TAKE_APPROVE
  WAREHOUSE_MANAGE
  PURCHASE_VIEW
  PURCHASE_CREATE
  PURCHASE_UPDATE
  PURCHASE_VOID
  CUSTOMER_VIEW
  CUSTOMER_CREATE
  CUSTOMER_UPDATE
  CUSTOMER_DELETE
  EXPENSE_VIEW
  EXPENSE_CREATE
  EXPENSE_UPDATE
  EXPENSE_DELETE
  RETURN_VIEW
  RETURN_CREATE
  SETTINGS_SHOP
  SETTINGS_ROLES
  AUDIT_VIEW
  REPORT_VIEW_SALES
  REPORT_EXPORT
  POS_ACCESS
  SHIPMENT_VIEW
  SHIPMENT_CREATE
  SHIPMENT_EDIT
  SHIPMENT_CANCEL
  QUOTATION_VIEW
  QUOTATION_CREATE
  QUOTATION_EDIT
  QUOTATION_CONFIRM
  ORDER_REQUEST_VIEW
  ORDER_REQUEST_CREATE
  ORDER_REQUEST_SUBMIT
  APPROVAL_VIEW
  APPROVAL_ACTION
  DELIVERY_VIEW
  DELIVERY_VALIDATE
  TAX_SETTINGS_VIEW
  TAX_SETTINGS_MANAGE
  TAX_REPORT_VIEW
  TAX_REPORT_POST
  SALE_UPDATE_LOCKED
  FINANCE_CONFIG
  STOCK_VIEW
  SUPPLIER_VIEW
  SUPPLIER_CREATE
  SUPPLIER_UPDATE
  SUPPLIER_DELETE
  INCOME_VIEW
}

Enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

Enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  WASTE
  CANCEL
  SALE_CANCEL
  PURCHASE_CANCEL
  RESERVATION
  RELEASE
  STOCK_TAKE_RECONCILIATION
}

Enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
  PROCESSING
}

Enum LogLevel {
  INFO
  WARN
  ERROR
}

Enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

Enum DeliveryStatus {
  DRAFT
  WAITING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

Enum SalesFlowMode {
  RETAIL
  ERP
}

Enum QuotationStatus {
  DRAFT
  SENT
  CONFIRMED
  CANCELLED
}

Enum OrderRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
